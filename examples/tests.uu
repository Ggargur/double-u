import stdio

fn sqrt_iter!(n: float, x: float) -> float {
    const refined = (x + n / x) / 2.0
    if refined == x { ^x }
    sqrt_iter(n, refined)
}

fn sqrt!(n: float) -> float {
    if n <= 0.0 { ^0.0 }
    sqrt_iter(n, n / 2.0)
}

entity Vector {
    x!: float
    y!: float
    z!: float

    fn squared_magnitude() -> float {
        x * x + y * y + z * z
    }

    fn magnitude() -> float {
        sqrt(squared_magnitude())
    }

    fn dot(other: Vector) -> float {
        self.x * other.x + self.y * other.y + self.z * other.z
    }

    fn normalized() -> Vector {
        const mag = magnitude()
        Vector(x / mag, y / mag, z / mag)
    }

    fn add!(other: Vector) -> Vector {
        Vector(self.x + other.x, self.y + other.y, self.z + other.z)
    }

    fn sub!(other: Vector) -> Vector {
        Vector(self.x - other.x, self.y - other.y, self.z - other.z)
    }

    fn mul!(scalar: float) -> Vector {
        Vector(self.x * scalar, self.y * scalar, self.z * scalar)
    }
}

entity Point = Vector

entity Collider {
    radius: float
    position: Point

    fn is_hit(other: Collider) -> bool {
        const dist2 = (self.position - other.position).squared_magnitude()
        const r_sum = self.radius + other.radius
        dist2 <= r_sum * r_sum
    }
}

entity Particle {
    velocity: Vector
    acceleration: Vector
    mass: float
    collider: Collider

    mut fn apply_impulse(impulse: Vector) -> unit {
        velocity = velocity + Vector(impulse.x / mass, impulse.y / mass, impulse.z / mass)
    }

    fn on_hit(other: Particle) -> unit {
        let relative_velocity = other.velocity - self.velocity
        const normal = velocity.normalized()
        let velocity_along_normal = relative_velocity.dot(normal)

        const restitution = 1.0
        const impulse_magnitude = (-(1.0 + restitution) * velocity_along_normal) / ((1.0 / self.mass) + (1.0 / other.mass))

        const impulse = normal * impulse_magnitude

        apply_impulse(impulse * -1.0)
        other.apply_impulse(impulse)
    }
}

fn main!() -> int {
    println("{sqrt(25.0)}")

    let p1 = Particle(Vector(0.0, 0.0, 0.0), Vector(0.0, 0.0, 0.0), 1.0, Collider(1.0, Point(1.0, 1.0, 1.0)))

    let p2 = Particle(Vector(0.0, 0.0, 0.0), Vector(0.0, 0.0, 0.0), 1.0, Collider(3.0, Point(1.0, 5.0000001, 1.0)))
    
    println("{p1.collider.is_hit(p2.collider)}")
    println("{1 == 1}")
    0
}
